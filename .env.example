# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
VERDECHAIN_VERSION=1.0.0

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://verdechain:secret@localhost:5432/verdechain_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=vc:

# ─── Stellar ─────────────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_ADMIN_PUBLIC_KEY=GXXX_REPLACE_ME
STELLAR_ADMIN_SECRET_KEY=SXXX_REPLACE_ME

# ─── Smart Contract Addresses ────────────────────────────────────────────────
CONTRACT_PRODUCT_REGISTRY=CXXX_REPLACE_ME
CONTRACT_LIFECYCLE_TRACKER=CYYY_REPLACE_ME
CONTRACT_ATTESTATION=CZZZ_REPLACE_ME
CONTRACT_GREENTAG_CERT=CAAA_REPLACE_ME
CONTRACT_VERIFIER_REGISTRY=CBBB_REPLACE_ME
CONTRACT_CARBON_ORACLE=CCCC_REPLACE_ME

# ─── Auth (SEP-10 + JWT) ─────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-random-secret-here
JWT_EXPIRY=24h
SEP10_SIGNING_KEY=SXXX_REPLACE_ME
SEP10_HOME_DOMAIN=api.verdechain.io

# ─── IPFS / Pinata ───────────────────────────────────────────────────────────
PINATA_API_KEY=xxx
PINATA_API_SECRET=xxx
PINATA_JWT=eyJhbGc_REPLACE
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ─── Attestation / Verifier Settings ─────────────────────────────────────────
VERIFIER_MIN_STAKE_XLM=1000
VERIFIER_DEFAULT_THRESHOLD=2
VERIFIER_QUORUM=3
VERIFIER_ESCALATION_QUORUM=5
APPROVAL_WINDOW_HOURS=168
SLASHING_PENALTY_PCT=20

# ─── Carbon Accounting ───────────────────────────────────────────────────────
CARBON_METHODOLOGY_DEFAULT=ghg_protocol
EMISSION_FACTOR_CACHE_TTL_HOURS=24
GRID_INTENSITY_REFRESH_HOURS=6

# ─── Certificate Generation ──────────────────────────────────────────────────
CERT_SIGNING_KEY=SXXX_REPLACE_ME
CERT_TEMPLATE_DIR=./templates/certificates
CERT_OUTPUT_DIR=/tmp/vc-certs
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# ─── Protocol Fees ────────────────────────────────────────────────────────────
PROTOCOL_FEE_BPS=50
VERIFIER_REWARD_BPS=30
INSURANCE_POOL_BPS=10
TREASURY_BPS=10

# ─── IoT Oracle ───────────────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtts://iot.verdechain.io:8883
MQTT_USERNAME=verdechain
MQTT_PASSWORD=xxx
ORACLE_SIGNING_SECRET=SXXX_REPLACE_ME
