<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{title}} - Carbon Neutral Certificate</title>
<style>
  @page { size: A4; margin: 20mm 15mm; }
  body { font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a1a; padding: 40px; background: #f0fdf4; }
  .cert { background: #fff; border-radius: 12px; padding: 40px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); border: 2px solid #86efac; }
  .leaf { text-align: center; font-size: 64px; margin-bottom: 8px; }
  h1 { text-align: center; color: #166534; font-size: 26px; margin-bottom: 4px; }
  .subtitle { text-align: center; color: #16a34a; font-size: 16px; font-weight: 500; margin-bottom: 30px; }
  .badge { text-align: center; margin: 20px 0; }
  .badge span { display: inline-block; background: #dcfce7; color: #166534; padding: 8px 24px; border-radius: 24px; font-size: 14px; font-weight: 600; }
  table { width: 100%; border-collapse: collapse; margin: 20px 0; }
  td { padding: 10px 12px; border-bottom: 1px solid #e5e7eb; }
  td:first-child { font-weight: 600; width: 140px; color: #374151; }
  .footprint { text-align: center; padding: 20px; background: #f0fdf4; border-radius: 8px; margin: 20px 0; }
  .footprint .amount { font-size: 36px; font-weight: 700; color: #166534; }
  .footprint .unit { font-size: 14px; color: #6b7280; }
  .footer { margin-top: 30px; text-align: center; font-size: 11px; color: #9ca3af; border-top: 1px solid #e5e7eb; padding-top: 16px; }
</style>
</head>
<body>
<div class="cert">
  <div class="leaf"></div>
  <h1>{{title}}</h1>
  <div class="subtitle">Carbon Neutral Certified</div>
  <div class="badge"><span>CO₂e Neutral</span></div>

  <table>
    <tr><td>Certificate ID</td><td>{{certificateId}}</td></tr>
    <tr><td>Product</td><td>{{productName}}</td></tr>
    {{#if productSku}}<tr><td>SKU</td><td>{{productSku}}</td></tr>{{/if}}
    {{#if productBatch}}<tr><td>Batch</td><td>{{productBatch}}</td></tr>{{/if}}
    <tr><td>Manufacturer</td><td>{{manufacturerName}}</td></tr>
    {{#if issuerName}}<tr><td>Certified By</td><td>{{issuerName}}</td></tr>{{/if}}
    <tr><td>Issued</td><td>{{formatDate issuedAt}}</td></tr>
    {{#if expiresAt}}<tr><td>Valid Until</td><td>{{formatDate expiresAt}}</td></tr>{{/if}}
  </table>

  <div class="footprint">
    <div class="amount">0</div>
    <div class="unit">kg CO₂e &mdash; Fully Offset</div>
  </div>

  {{#if description}}
  <p style="color: #555; font-style: italic;">{{description}}</p>
  {{/if}}

  <div class="footer">
    VerdeChain &bull; Verified Carbon Neutral<br>
    Offsets verified and recorded on the Stellar network.
  </div>
</div>
</body>
</html>
