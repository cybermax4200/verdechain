<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <title>{{title}} - Certificate of Origin</title>
    <style>
      @page {
        size: A4;
        margin: 20mm 15mm;
      }
      body {
        font-family: 'Times New Roman', Times, serif;
        color: #1a1a1a;
        padding: 40px;
      }
      .border {
        border: 3px double #166534;
        padding: 30px;
      }
      h1 {
        text-align: center;
        color: #166534;
        font-size: 24px;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 2px;
      }
      .subtitle {
        text-align: center;
        color: #666;
        font-size: 14px;
        margin-bottom: 30px;
      }
      .seal {
        text-align: center;
        font-size: 48px;
        margin: 20px 0;
        color: #166534;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 20px 0;
      }
      td {
        padding: 10px 12px;
        border-bottom: 1px solid #d1d5db;
      }
      td:first-child {
        font-weight: bold;
        width: 140px;
        color: #374151;
      }
      .footer {
        margin-top: 40px;
        text-align: center;
        font-size: 11px;
        color: #9ca3af;
        border-top: 1px solid #d1d5db;
        padding-top: 16px;
      }
      .verification {
        text-align: center;
        margin-top: 20px;
        font-size: 12px;
      }
      .verification a {
        color: #166534;
      }
    </style>
  </head>
  <body>
    <div class='border'>
      <h1>Certificate of Origin</h1>
      <div class='subtitle'>VerdeChain Certified &mdash; {{certType}}</div>
      <div class='seal'>&nbsp;</div>

      <table>
        <tr><td>Certificate ID</td><td>{{certificateId}}</td></tr>
        <tr><td>Product Name</td><td>{{productName}}</td></tr>
        {{#if productSku}}<tr><td>SKU</td><td>{{productSku}}</td></tr>{{/if}}
        {{#if productBatch}}<tr><td>Batch</td><td>{{productBatch}}</td></tr>{{/if}}
        <tr><td>Manufacturer</td><td>{{manufacturerName}}</td></tr>
        {{#if manufacturerCountry}}<tr><td>Country of Origin</td><td
            >{{manufacturerCountry}}</td></tr>{{/if}}
        {{#if issuerName}}<tr><td>Issued By</td><td>{{issuerName}}</td></tr>{{/if}}
        <tr><td>Issued</td><td>{{formatDate issuedAt}}</td></tr>
        {{#if expiresAt}}<tr><td>Expires</td><td>{{formatDate expiresAt}}</td></tr>{{/if}}
      </table>

      {{#if description}}
        <p style='margin-top: 16px; font-style: italic; color: #555;'>{{description}}</p>
      {{/if}}

      <div class='verification'>
        Verify at:
        <a href='{{verificationUrl}}'>{{verificationUrl}}</a>
      </div>

      <div class='footer'>
        VerdeChain &bull; Decentralized Supply Chain Attestation<br />
        This certificate is cryptographically signed and stored on the Stellar network.
      </div>
    </div>
  </body>
</html>